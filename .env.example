# Local demo chain used by scripts/demo-local.sh.
LOCAL_RPC_URL=http://127.0.0.1:8545
LOCAL_CHAIN_ID=31337

# Public Anvil test key. Unsafe outside local demos.
LOCAL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Manual contract deployment defaults.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Sepolia portfolio deployment.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
ETHERSCAN_API_KEY=

# Fill from blockchain/evm/deployments/31337.json after local deployment,
# or blockchain/evm/deployments/11155111.json after Sepolia deployment.
IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Backend service.
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
BLOCKCHAIN_ENABLED=true
ADMIN_API_TOKEN=local-admin-token
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BACKEND_API_BASE_URL=http://localhost:8080
AUTH_MFA_CODE=123456
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DATABASE_URL='jdbc:h2:file:./data/compliance-service;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH'
DATABASE_USERNAME=sa
DATABASE_PASSWORD=
DATABASE_DRIVER=org.h2.Driver

# Frontend dashboard.
NEXT_PUBLIC_API_BASE_URL=/api/backend
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_BLOCK_EXPLORER_URL=
