{
  "name": "rwa-compliance-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "mkdir -p .home/.cache/next-swc .cache && HOME=$PWD/.home XDG_CACHE_HOME=$PWD/.cache next build",
    "start": "next start",
    "lint": "next lint",
    "local:bootstrap": "bash ./scripts/bootstrap-local.sh",
    "local:stop": "bash ./scripts/stop-local.sh",
    "typecheck": "tsc --noEmit",
    "test": "mkdir -p .vitest-temp && TMPDIR=$PWD/.vitest-temp vitest run",
    "test:watch": "mkdir -p .vitest-temp && TMPDIR=$PWD/.vitest-temp vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "5.100.9",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-is": "^19.2.0",
    "recharts": "^3.8.1",
    "viem": "2.48.11",
    "wagmi": "3.6.12"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "10.3.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
