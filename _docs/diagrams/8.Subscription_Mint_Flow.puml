@startuml
title RWA Tokenized Compliance System - Subscription and Mint Flow

actor Investor
actor "Issuer Admin" as Issuer
participant "Investor Dashboard" as InvestorUI
participant "Compliance Service" as Compliance
participant "Asset/Fund Service" as AssetService
database "PostgreSQL" as DB
participant "Permissioned Token" as Token

Investor -> InvestorUI : Request subscription
InvestorUI -> AssetService : POST subscription
AssetService -> Compliance : Validate profile,\nrules, and identity state
Compliance --> AssetService : Eligible or rejected
AssetService -> DB : Store pending subscription
Issuer -> AssetService : Approve subscription
AssetService -> Token : mint(approvedWallet, amount)
Token --> AssetService : Mint tx receipt
AssetService -> DB : Store position and tx hash
AssetService --> InvestorUI : Subscription approved and minted
@enduml