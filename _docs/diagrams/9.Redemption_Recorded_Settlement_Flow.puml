@startuml
title RWA Tokenized Compliance System - Redemption and Recorded Settlement Flow

actor Investor
actor "Issuer Admin" as Issuer
participant "Investor Dashboard" as InvestorUI
participant "Asset/Fund Service" as AssetService
participant "Compliance Service" as Compliance
database "PostgreSQL" as DB

Investor -> InvestorUI : Request redemption
InvestorUI -> AssetService : POST redemption
AssetService -> Compliance : Validate profile,\nlockup, and identity state
Compliance --> AssetService : Allowed or rejected
AssetService -> DB : Store pending redemption
Issuer -> AssetService : Approve redemption
AssetService -> Compliance : Recheck eligibility and balance
Compliance --> AssetService : Allowed
AssetService -> DB : Decrement persisted position
AssetService -> DB : Store simulated settlement and audit event
AssetService --> InvestorUI : Redemption approved and recorded
@enduml