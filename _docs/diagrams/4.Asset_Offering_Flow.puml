@startuml
title RWA Tokenized Compliance System - Asset Offering Flow

actor Investor
actor "Issuer Admin" as Admin
participant "Investor Dashboard" as InvestorUI
participant "Admin Dashboard" as AdminUI
participant "Compliance API" as API
database "PostgreSQL" as DB

API -> DB : Seed demo asset if empty
Investor -> InvestorUI : Browse offerings
InvestorUI -> API : GET /api/assets
API -> DB : Read active offerings
API --> InvestorUI : Asset name, symbol, NAV, cap, token address
Admin -> AdminUI : Create draft offering
AdminUI -> API : POST /api/admin/assets\nX-Admin-Token
API -> DB : Persist asset offering
API -> DB : Store ASSET_CREATED audit event
API --> AdminUI : Created asset config
@enduml